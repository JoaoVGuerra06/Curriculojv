.social-links {
  display: flex;
  justify-content: center;
  gap: 15px;
  margin-top: 10px;
}

.social-icon {
  width: 40px;
  height: 40px;
  background: var(--cor-clara);  /* branco */
  color: var(--cor-fundo);       /* preto */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  font-size: 1.2rem;
  transition: background 0.3s, color 0.3s;
}

.social-icon:hover {
  background: var(--cor-accento); /* verde */
  color: var(--cor-clara);        /* branco */
}

@keyframes girar {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@media (max-width: 768px) {
  header { padding: 80px 20px; }
  .card { padding: 16px; }
}



/* Menu lateral */
.menu {
  position: fixed;
  top: 0;
  right: -250px; /* escondido */
  width: 250px;
  height: 100%;
  background: var(--cor-clara);
  transition: right 0.3s ease;
  padding-top: 80px;
  z-index: 150;
}

.menu ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.menu li {
  margin: 20px 0;
  text-align: center;
  margin-top: 50px;
}

.menu a {
  color: var(--cor-accento);
  font-size: 1.2rem;
  text-decoration: none;
  transition: color 0.3s;
}

.menu a:hover {
  color: #000;
}

.menu h2 {
  margin-top: 10px;
  font-size: 2rem;
  color: var(--cor-accento);
  text-align: center;
}

/* Quando o menu está ativo */
.menu.active {
  right: 0;
}

.social-buttons {
  display: flex;
  flex-direction: column;
  gap: 30px;
  align-items:center;
}

.social-buttons img {
  width: 90vw;    /* toda a largura da tela */
  height: 120px;   /* altura fixa do banner */
  overflow: hidden; 
  border-radius: 16px;  
  cursor: pointer;
}

/* kenburns-top effect */

.social-buttons img:hover {
  -webkit-animation: kenburns-top 5s ease-out both;
          animation: kenburns-top 5s ease-out both;
}


@-webkit-keyframes kenburns-top {
  0% {
    -webkit-transform: scale(1) translateY(0);
            transform: scale(1) translateY(0);
    -webkit-transform-origin: 50% 16%;
            transform-origin: 50% 16%;
  }
  100% {
    -webkit-transform: scale(1.09) translateY(-15px);
            transform: scale(1.09) translateY(-15px);
    -webkit-transform-origin: top;
            transform-origin: top;
  }
}

@keyframes kenburns-top {
  0% {
    -webkit-transform: scale(1) translateY(0);
            transform: scale(1) translateY(0);
    -webkit-transform-origin: 50% 16%;
            transform-origin: 50% 16%;
  }
  100% {
    -webkit-transform: scale(1.09) translateY(-15px);
            transform: scale(1.09) translateY(-15px);
    -webkit-transform-origin: top;
            transform-origin: top;
  }
}
